
import os
import re

import ee
import geemap

PROJECT = "bigearthdata"

def init_earth_engine():
    try:
        ee.Initialize(project=PROJECT)
        print("Earth Engine initialised.")
    except ee.EEException:
        print("No saved credentials found – starting authentication flow …")
        ee.Authenticate()
        ee.Initialize(project=PROJECT)
        print("Earth Engine initialised successfully.")


def download_dynamic_world_local(image_id, output_dir="./output"):
    os.makedirs(output_dir, exist_ok=True)

    dw = (
        ee.ImageCollection("GOOGLE/DYNAMICWORLD/V1")
        .filter(ee.Filter.eq("system:index", image_id))
    )

    dw_image = ee.Image(dw.first())
    if dw_image.getInfo() is None:
        raise ValueError(f"No Dynamic World image found for image {image_id}.")

    # 4. Download directly to local disk
    output_path = os.path.join(output_dir, f"DW_{image_id}.tif")

    DW_PROB_BANDS = [
        "water",
        "trees",
        "grass",
        "flooded_vegetation",
        "crops",
        "shrub_and_scrub",
        "built",
        "bare",
        "snow_and_ice",
    ]

    geemap.ee_export_image(
        dw_image.select(DW_PROB_BANDS),   # or just dw_image to get all bands including label
        filename=output_path,
        scale=140,
        region=dw_image.geometry(),
        crs=dw_image.select(0).projection().crs().getInfo(),
    )
    # geemap.ee_export_image(
    #     dw_image.select("label"),
    #     filename=output_path,
    #     scale=30,
    #     region=dw_image.geometry(),
    #     crs=dw_image.select(0).projection().crs().getInfo(),
    #     file_per_band=False,
    # )

    print(f"Saved to: {output_path}")
    return output_path


if __name__ == "__main__":
    init_earth_engine()
    # download_dynamic_world_local(
    #     safe_filename="S2B_MSIL1C_20260517T073609_N0512_R092_T36JUN_20260517T111451.SAFE",
    #     output_dir="./output"
    # )
    image_id = "20211019T154251_20211019T154735_T18TYM"  # the part after the collection path
    download_dynamic_world_local(image_id=image_id, output_dir="./output")